    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties/>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="var1" expression="StringHandling.TRIM(row2.Camp == null ? &quot;&quot; : row2.Camp)&#xD;&#xA;    .toLowerCase()&#xD;&#xA;    .replace(&quot;é&quot;, &quot;e&quot;)&#xD;&#xA;    .replace(&quot;è&quot;, &quot;e&quot;)&#xD;&#xA;    .replace(&quot;ê&quot;, &quot;e&quot;)&#xD;&#xA;    .replace(&quot;à&quot;, &quot;a&quot;)&#xD;&#xA;    .replace(&quot;â&quot;, &quot;a&quot;)&#xD;&#xA;    .replace(&quot;î&quot;, &quot;i&quot;)&#xD;&#xA;    .replace(&quot;ï&quot;, &quot;i&quot;)&#xD;&#xA;    .replace(&quot;ô&quot;, &quot;o&quot;)&#xD;&#xA;    .replace(&quot;ù&quot;, &quot;u&quot;)&#xD;&#xA;    .replace(&quot;û&quot;, &quot;u&quot;)&#xD;&#xA;    .replace(&quot;ç&quot;, &quot;c&quot;)&#xD;&#xA;    .replace(&quot;’&quot;, &quot;'&quot;)&#xD;&#xA;    .replace(&quot;'&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;-&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;(&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;)&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;/&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;1&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;2&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;3&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;4&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;5&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;6&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;7&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;8&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;9&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;0&quot;, &quot; &quot;)&#xD;&#xA;    .replaceAll(&quot;\\s+&quot;, &quot; &quot;)&#xD;&#xA;    .trim() " type="id_String"/>
      </varTables>
      <outputTables sizeState="INTERMEDIATE" name="out1">
        <mapperTableEntries name="camp_libelle" expression="StringHandling.TRIM(row2.Camp == null ? &quot;&quot; : row2.Camp) " type="id_String" nullable="true"/>
        <mapperTableEntries name="categorie_cout" expression="&quot;Transport&quot;" type="id_String" nullable="true"/>
