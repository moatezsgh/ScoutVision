    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties shellMaximized="true"/>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="type_camp_normalise" expression="StringHandling.TRIM(row1.Type_de_Camp == null ? &quot;&quot; : row1.Type_de_Camp)&#xD;&#xA;    .toLowerCase()&#xD;&#xA;    .replace(&quot;é&quot;, &quot;e&quot;)&#xD;&#xA;    .replace(&quot;è&quot;, &quot;e&quot;)&#xD;&#xA;    .replace(&quot;ê&quot;, &quot;e&quot;)&#xD;&#xA;    .replace(&quot;à&quot;, &quot;a&quot;)&#xD;&#xA;    .replace(&quot;â&quot;, &quot;a&quot;)&#xD;&#xA;    .replace(&quot;î&quot;, &quot;i&quot;)&#xD;&#xA;    .replace(&quot;ï&quot;, &quot;i&quot;)&#xD;&#xA;    .replace(&quot;ô&quot;, &quot;o&quot;)&#xD;&#xA;    .replace(&quot;ù&quot;, &quot;u&quot;)&#xD;&#xA;    .replace(&quot;û&quot;, &quot;u&quot;)&#xD;&#xA;    .replace(&quot;ç&quot;, &quot;c&quot;)&#xD;&#xA;    .replace(&quot;’&quot;, &quot;'&quot;)&#xD;&#xA;    .replace(&quot;'&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;-&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;(&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;)&quot;, &quot; &quot;)&#xD;&#xA;    .replace(&quot;/&quot;, &quot; &quot;)&#xD;&#xA;    .replaceAll(&quot;\\s+&quot;, &quot; &quot;)&#xD;&#xA;    .trim() " type="id_String"/>
      </varTables>
      <outputTables sizeState="INTERMEDIATE" name="out1">
        <mapperTableEntries name="libelle_Camp" expression="StringHandling.TRIM(row1.Type_de_Camp == null ? &quot;&quot; : row1.Type_de_Camp) " type="id_String" nullable="true"/>
        <mapperTableEntries name="type_camp" expression="Var.type_camp_normalise.contains(&quot;printemps&quot;) ? &quot;PRINTEMPS&quot; :&#xD;&#xA;&#xD;&#xA;Var.type_camp_normalise.contains(&quot;ete&quot;) ? &quot;ETE&quot; :&#xD;&#xA;&#xD;&#xA;Var.type_camp_normalise.contains(&quot;mobile&quot;) ? &quot;MOBILE&quot; :&#xD;&#xA;&#xD;&#xA;Var.type_camp_normalise.contains(&quot;preparatoire&quot;) ? &quot;PREPARATOIRE&quot; :&#xD;&#xA;&#xD;&#xA;&quot;AUTRE&quot; " type="id_String" nullable="true"/>
        <mapperTableEntries name="niveau_camp" expression="Var.type_camp_normalise.contains(&quot;jeune&quot;) ? &quot;Jeunes&quot; :&#xD;&#xA;Var.type_camp_normalise.contains(&quot;avance&quot;) ? &quot;Avancé&quot; :&#xD;&#xA;&quot;Standard&quot; " type="id_String" nullable="true"/>
      </outputTables>
      <inputTables sizeState="INTERMEDIATE" name="row1" matchingMode="UNIQUE_MATCH" lookupMode="LOAD_ONCE">
